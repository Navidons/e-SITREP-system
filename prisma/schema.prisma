generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ReportingProfile {
  land
  air
}

model BorderStation {
  id        Int      @id @default(autoincrement())
  code      String   @unique @db.VarChar(20)
  name      String   @unique @db.VarChar(100)
  cluster   String?  @db.VarChar(50)
  type      String?  @db.VarChar(30)
  reportingProfile ReportingProfile @default(land) @map("reporting_profile")
  location     String?
  displayOrder Int      @default(999) @map("display_order")
  active       Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users   User[]
  reports StationDailyReport[]

  @@map("border_stations")
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(50)
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          Int    @id @default(autoincrement())
  name        String @unique @db.VarChar(100)
  description String?

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       Int @map("role_id")
  permissionId Int @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model User {
  id           Int       @id @default(autoincrement())
  username     String    @unique @db.VarChar(50)
  email        String?   @unique @db.VarChar(100)
  passwordHash String    @map("password_hash")
  fullName     String    @map("full_name") @db.VarChar(100)
  stationId           Int?               @map("station_id")
  countryCodeFormat   CountryCodeFormat  @default(alpha2) @map("country_code_format")
  isActive            Boolean            @default(true) @map("is_active")
  lastLogin           DateTime?          @map("last_login")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  station       BorderStation?       @relation(fields: [stationId], references: [id])
  userRoles     UserRole[]
  reports            StationDailyReport[] @relation("SubmittedBy")
  reportsRejected    StationDailyReport[] @relation("RejectedBy")
  dailyEntries       DailyEntry[]
  auditLogs          AuditLog[]
  assignedRoles      UserRole[]           @relation("AssignedBy")
  amendmentsRequested DayAmendment[]      @relation("AmendmentRequestedBy")
  amendmentsReviewed  DayAmendment[]      @relation("AmendmentReviewedBy")

  @@map("users")
}

model UserRole {
  userId     Int      @map("user_id")
  roleId     Int      @map("role_id")
  assignedBy Int?     @map("assigned_by")
  assignedAt DateTime @default(now()) @map("assigned_at")

  user     User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     Role  @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assigner User? @relation("AssignedBy", fields: [assignedBy], references: [id])

  @@id([userId, roleId])
  @@map("user_roles")
}

enum ReportStatus {
  draft
  submitted
  reviewed
  verified
  approved
  rejected
}

enum CountryCodeFormat {
  alpha2
  alpha3
}

/// One record per station per calendar day — all entries for that day link here.
model StationDailyReport {
  id               Int          @id @default(autoincrement())
  stationId        Int          @map("station_id")
  reportDate       DateTime     @map("report_date") @db.Date
  submittedById    Int?         @map("submitted_by")
  submissionTime   DateTime?    @map("submission_time")
  status           ReportStatus @default(draft)
  rejectionReason  String?      @map("rejection_reason")
  rejectedById     Int?         @map("rejected_by")
  rejectedAt       DateTime?    @map("rejected_at")
  staffOnDuty      Int          @default(0) @map("staff_on_duty")
  medicalScreening String?      @map("medical_screening")
  generalRemarks   String?      @map("general_remarks")
  urgentMatters      String?      @map("urgent_matters")
  inadmissibleCount  Int          @default(0) @map("inadmissible_count")
  staffLeaveNotes    String?      @map("staff_leave_notes")
  openedAt           DateTime     @default(now()) @map("opened_at")

  station     BorderStation @relation(fields: [stationId], references: [id])
  submittedBy User?         @relation("SubmittedBy", fields: [submittedById], references: [id])
  rejectedBy  User?         @relation("RejectedBy", fields: [rejectedById], references: [id])
  entries     DailyEntry[]
  incidents   Incident[]
  amendments  DayAmendment[]

  @@unique([stationId, reportDate])
  @@index([stationId, reportDate])
  @@index([status])
  @@map("station_daily_reports")
}

enum DailyEntryType {
  arrival
  departure
  asylum_seeker
  refugee
  /// Entebbe / airport: passengers on a flight
  flight_arrival
  flight_departure
  deportee
  returned_person
  offloaded
  denied_entry
}

enum AmendmentAction {
  add_entry
  delete_entry
  update_entry
}

enum AmendmentStatus {
  pending
  approved
  rejected
}

/// Correction queued for HQ approval before changing submitted day data.
model DayAmendment {
  id              Int              @id @default(autoincrement())
  reportId        Int              @map("report_id")
  status          AmendmentStatus  @default(pending)
  action          AmendmentAction
  payload         Json
  reason          String?
  reviewComment   String?          @map("review_comment")
  targetEntryId   Int?             @map("target_entry_id")
  requestedById   Int              @map("requested_by")
  reviewedById    Int?             @map("reviewed_by")
  createdAt       DateTime         @default(now()) @map("created_at")
  resolvedAt      DateTime?        @map("resolved_at")

  report      StationDailyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  requestedBy User               @relation("AmendmentRequestedBy", fields: [requestedById], references: [id])
  reviewedBy  User?              @relation("AmendmentReviewedBy", fields: [reviewedById], references: [id])

  @@index([reportId, status])
  @@index([status, createdAt])
  @@map("day_amendments")
}

/// Each log batch during the day (added at different times).
model DailyEntry {
  id              Int            @id @default(autoincrement())
  reportId        Int            @map("report_id")
  entryType       DailyEntryType @map("entry_type")
  nationalityCode String?        @map("nationality_code") @db.VarChar(10)
  male            Int            @default(0)
  female          Int            @default(0)
  flightNumber    String?        @map("flight_number") @db.VarChar(20)
  route           String?        @db.VarChar(120)
  shift           String?        @db.VarChar(1)
  passportNo      String?        @map("passport_no") @db.VarChar(50)
  personName      String?        @map("person_name") @db.VarChar(120)
  recordedAt      DateTime       @default(now()) @map("recorded_at")
  enteredById     Int?           @map("entered_by")
  notes           String?
  createdAt       DateTime       @default(now()) @map("created_at")

  report    StationDailyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  enteredBy User?              @relation(fields: [enteredById], references: [id])

  @@index([reportId, recordedAt])
  @@index([reportId, entryType])
  @@map("daily_entries")
}

model Incident {
  id           Int      @id @default(autoincrement())
  reportId     Int      @map("report_id")
  incidentType String?  @map("incident_type") @db.VarChar(100)
  description  String
  passportNo   String?  @map("passport_no") @db.VarChar(50)
  personName   String?  @map("person_name") @db.VarChar(100)
  actionTaken  String?  @map("action_taken")
  createdAt    DateTime @default(now()) @map("created_at")

  report StationDailyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@map("incidents")
}

model AuditLog {
  id         BigInt   @id @default(autoincrement())
  userId     Int?     @map("user_id")
  action     String   @db.VarChar(50)
  entityType String   @map("entity_type") @db.VarChar(50)
  entityId   Int?     @map("entity_id")
  oldValues  Json?    @map("old_values")
  newValues  Json?    @map("new_values")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@map("audit_logs")
}
